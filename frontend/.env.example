# Sample environment variables for frontend
# Copy to .env.development or .env.production and fill in your values

# API Keys - keep these secure and never commit to version control!
VITE_RAPIDAPI_KEY=your_rapidapi_key_here
VITE_RAPIDAPI_HOST=judge0-ce.p.rapidapi.com

# Firebase configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Connection URLs - Set these differently for production
# Development values:
VITE_API_URL=http://localhost:3001
VITE_SOCKET_URL=http://localhost:3001
VITE_PEER_HOST=localhost
VITE_PEER_PORT=9000
VITE_PEER_PATH=/peerjs
VITE_PEER_KEY=codecolab

# Production values (uncomment for production):
# VITE_API_URL=https://api.codecolab.com
# VITE_SOCKET_URL=https://api.codecolab.com
# VITE_PEER_HOST=api.codecolab.com
# VITE_PEER_PORT=443
# VITE_PEER_PATH=/peerjs
# VITE_PEER_KEY=codecolab

# Socket.io connection settings
VITE_SOCKET_RECONNECTION_ATTEMPTS=5
VITE_SOCKET_RECONNECTION_DELAY=1000
VITE_SOCKET_RECONNECTION_DELAY_MAX=5000

# Log level: 0=none, 1=error, 2=warn, 3=info, 4=debug
# Use lower levels in production (0 or 1)
VITE_LOG_LEVEL=3

# WebRTC limitations
VITE_MAX_PEER_CONNECTIONS=10
VITE_MAX_RECONNECTION_ATTEMPTS=3
VITE_RECONNECTION_DELAY=2000

# WebRTC TURN server (required for reliable WebRTC connections in production)
VITE_TURN_SERVER_URL=turn:your-turn-server.com:3478
VITE_TURN_USERNAME=your_username
VITE_TURN_CREDENTIAL=your_password 